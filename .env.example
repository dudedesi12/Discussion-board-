# Copy to .env and fill in real values.
# Never commit .env to source control.

FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Database (default: SQLite for local dev)
DATABASE_URL=sqlite:///discussion_board.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AI Feature Flag – set to false to disable all AI processing
AI_ENABLED=true

# Safety thresholds
TOXICITY_THRESHOLD=0.70
RESOURCE_CONFIDENCE_THRESHOLD=0.80
AGENT_CONFIDENCE_THRESHOLD=0.70

# LLM backend (via LiteLLM)
LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=
